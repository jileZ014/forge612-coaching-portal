rules_version = '2';
// Updated 2026-05-04 — added families/communications/documents (coach-only PII)
// for v0 CRM port from genesis-elite. Existing parents/ + teams/{teamId}/* rules preserved.

service cloud.firestore {
  match /databases/{database}/documents {

    // Parents collection — used by Flight_Pay invoicing dashboard (flat collection)
    // TODO: tighten once login is wired across the parents path
    match /parents/{parentId} {
      allow read, write: if true;
    }

    // Helper: check if the authenticated user is the coach for this team
    function isCoach(teamId) {
      return request.auth != null &&
        request.auth.token.email == get(/databases/$(database)/documents/teams/$(teamId)).data.coachEmail;
    }

    // Team document — public read for team info, coach write
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isCoach(teamId);
    }

    // Players — public read (for pay page lookup via client), coach write
    match /teams/{teamId}/players/{playerId} {
      allow read: if true;
      allow write: if isCoach(teamId);
    }

    // Fees — public read (for pay page), coach write
    match /teams/{teamId}/fees/{feeId} {
      allow read: if true;
      allow write: if isCoach(teamId);
    }

    // Payments — public read (for pay page lookup), coach write
    match /teams/{teamId}/payments/{paymentId} {
      allow read: if true;
      allow write: if isCoach(teamId);
    }

    // Schedule — public read, coach write
    match /teams/{teamId}/schedule/{eventId} {
      allow read: if true;
      allow write: if isCoach(teamId);
    }

    // CRM v0 — coach-only (PII)
    // Families: parent contacts, lifecycle, tags, do-not-contact flag
    match /teams/{teamId}/families/{familyId} {
      allow read, write: if isCoach(teamId);
    }

    // Communications: SMS/email/notes log per family
    match /teams/{teamId}/communications/{commId} {
      allow read, write: if isCoach(teamId);
    }

    // Documents: medical forms, waivers, photos (metadata; binaries in Storage)
    match /teams/{teamId}/documents/{docId} {
      allow read, write: if isCoach(teamId);
    }

    // SD Tournament verification checklist — coach-only writes from /dashboard/sd-tournament/verification
    match /teams/{teamId}/sdTournamentVerification/{paymentId} {
      allow read, write: if isCoach(teamId);
    }

    // SD Tournament roster — public read+write so the 6 head coaches can submit
    // their team's roster via shared link /roster/{teamCode} without an account.
    // Trust model: links are shared only with the 6 coaches Jonas knows; data is
    // basic roster info (name, age, grade, HS, parent contact) already shared
    // with tournament organizers. Tighten with team-code tokens if needed later.
    match /teams/{teamId}/sdTournamentRoster/{playerId} {
      allow read, write: if true;
    }
  }
}
